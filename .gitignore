# ============================================================================
# Dotfiles .gitignore
# ============================================================================

# === BACKUP FILES ===
*.backup
*.backup.*
*.swp
*.swo
*~
.#*

# === OS SPECIFIC ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# === IDE SPECIFIC (if not using) ===
# Uncomment if you don't want to version IDE files:
.idea/
.vscode/
*.iml

# === LOCAL/SENSITIVE ===
# Files that contain sensitive data:
*.local
*.private
*.secret
git/.gitconfig.local
shell/.ssh_config.local

# === TEMPORARY FILES ===
# Temporary files generated by various tools:
*.tmp
*.log
*.lock

# === NODE ===
node_modules/
package-lock.json
yarn.lock

# === PYTHON ===
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# === BUILD OUTPUT ===
build/
dist/
target/

# === EDITOR SPECIFIC ===
.vscode/settings.json.bak
.idea/workspace.xml

# === CUSTOM LOCAL BRANCHES ===
# Local test branches (optional):
# /local/
# /testing/

# === DON'T IGNORE ===
# But DO track these essential files:
!install.sh
!README.md
!.gitignore